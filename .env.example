# Copy this file to .env and fill in your values.
# Get your Groq API key for free at: https://console.groq.com
# Get your Resend API key for free at: https://resend.com
# NEVER commit .env to version control.

GROQ_API_KEY=gsk_...
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=you@example.com

# Optional: override Groq model selection
# GROQ_MATCH_MODEL=llama-3.1-8b-instant        # fast + cheap (default)
# GROQ_COVER_LETTER_MODEL=llama-3.3-70b-versatile  # quality writing (default)

# Optional: override default profile/data paths
# USER_PROFILE_PATH=config/user_profile.yaml
# DB_PATH=data/jobs.db
