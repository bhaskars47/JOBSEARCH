# ─────────────────────────────────────────────
#  Example User Profile — Job Search Automation
#  Copy to `user_profile.yaml` and edit.
# ─────────────────────────────────────────────

# Full name and contact info (used in auto-apply pre-fill)
name: "Jane Doe"
email: "jane.doe@example.com"
phone: "+1-555-0123"

# Path to your resume file (used for upload in semi-auto apply)
resume_path: "~/Documents/Resume.pdf"

# Job titles you're targeting
target_titles:
  - Software Engineer
  - QA Engineer
  - Automation Engineer

# Your core skills
skills:
  - Test automation
  - Python
  - Jenkins
  - CI/CD
  - Git

# Years of total QA/Engineering experience
years_experience: 5

# Preferred work locations (include "Remote" if open to it)
target_locations:
  - Remote
  - New York, NY
  - San Francisco, CA

# Minimum annual salary (in local currency; 0 = no filter)
salary_min: 0

# Companies to exclude from results
excluded_companies: []

# Industries to exclude
excluded_industries:
  - gambling
  - adult content
